# ─────────────────────────────────────────────────────────────
#  E-LOGISTIC — szablon zmiennych środowiskowych
#  Skopiuj do `apps/web/.env.local` (Next) i uzupełnij. NIGDY nie commituj wartości.
#  Źródło prawdy dla listy zmiennych: turbo.json → globalEnv.
# ─────────────────────────────────────────────────────────────

# ── Supabase (web) ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # tylko serwer/Edge — NIGDY w kliencie
SUPABASE_DB_PASSWORD=               # opcjonalnie: bezpośrednie migracje (pooler)

# ── Supabase (mobile / Expo) ──────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── Routing TIR + myto (serwerowo, /api/route) ────────────────
HERE_API_KEY=                       # priorytet: realny routing TIR + myto + ruch
GRAPHHOPPER_API_KEY=                # fallback (free tier: tylko car)

# ── Render mapy / geokoder (klient) ───────────────────────────
NEXT_PUBLIC_MAPTILER_KEY=           # style wektorowe, satelita, teren 3D, geokoder

# ── Domena (WebAuthn/passkey: zaufany origin) ─────────────────
NEXT_PUBLIC_SITE_URL=https://e-logistic-one.vercel.app

# ── Powiadomienia push (Web Push) — patrz DEPLOY.md §7 ────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=                  # sekret
VAPID_SUBJECT=mailto:admin@e-logistic.app
CRON_SECRET=                        # chroni /api/cron/notify (Vercel Cron)

# ── Ceny paliwa (serwerowo, /api/fuel-prices) ─────────────────
FUEL_PRICE_API_KEY=                 # Tankerkönig (DE) — opcjonalne

# ── Fakturownia (serwerowo, /api/fakturownia/export) ──────────
FAKTUROWNIA_API_TOKEN=              # sekret: Ustawienia > Integracja > Kod API
FAKTUROWNIA_DOMAIN=                 # subdomena konta (np. „mojafirma" z mojafirma.fakturownia.pl)

# ─────────────────────────────────────────────────────────────
#  PLANOWANE / jeszcze NIEUŻYWANE w kodzie (nie ustawiaj na razie):
#  PowerSync (offline), Twilio (SMS zaproszeń), Sentry (obserwowalność),
#  OAuth Google/Apple/Microsoft (konfiguracja w panelu Supabase, nie env).
# ─────────────────────────────────────────────────────────────

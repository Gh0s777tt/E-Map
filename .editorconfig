# EditorConfig — spójne formatowanie w edytorach (zgodne z biome.json)
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

# Markdown: końcowe spacje bywają celowe (twarde złamanie wiersza)
[*.md]
trim_trailing_whitespace = false

# Make/gitmodules wymagają tabów
[{Makefile,*.mk}]
indent_style = tab

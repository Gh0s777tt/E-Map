{
  "expo": {
    "name": "E-Logistic",
    "slug": "e-logistic",
    "scheme": "elogistic",
    "version": "0.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#0a0a0a",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ghostempire.elogistic"
    },
    "android": {
      "package": "com.ghostempire.elogistic",
      "edgeToEdgeEnabled": true
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}

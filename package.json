{
  "name": "e-logistic",
  "version": "1.177.0",
  "private": true,
  "description": "E-Logistic — platforma dla kierowców, spedytorów i firm transportowych (GH0ST EMPIRE)",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",

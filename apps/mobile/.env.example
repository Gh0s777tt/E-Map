# Konfiguracja Supabase dla aplikacji mobilnej (Expo).
# Skopiuj do `.env` (Expo wczytuje zmienne z prefiksem EXPO_PUBLIC_ automatycznie).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Mapa (klient-side; klucze publiczne/domenowo restrykcjonowane).
EXPO_PUBLIC_MAPTILER_KEY=            # styl wektorowy mapy (fallback: raster OSM)
# TomTom (#356): włącza lepszy geokoder, routing TIR z ruchem na żywo na urządzeniu
# oraz „paliwo po drodze" (POI wzdłuż trasy). Pusty → mapa działa na MapTiler/OSM + web /api/route.
EXPO_PUBLIC_TOMTOM_KEY=

# ─────────────────────────────────────────────────────────────
#  E-LOGISTIC — szablon zmiennych środowiskowych
#  Skopiuj do `apps/web/.env.local` (Next) i uzupełnij. NIGDY nie commituj wartości.
#  Źródło prawdy dla listy zmiennych: turbo.json → globalEnv.
# ─────────────────────────────────────────────────────────────

# ── Supabase (web) ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # tylko serwer/Edge — NIGDY w kliencie
SUPABASE_DB_PASSWORD=               # opcjonalnie: bezpośrednie migracje (pooler)

# ── Supabase (mobile / Expo) ──────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── Routing TIR + myto + ruch (serwerowo, /api/route, /api/traffic) ──
HERE_API_KEY=                       # routing TIR + myto; ruch na żywo (/api/traffic) wymaga planu HERE z dodatkiem Traffic
TOMTOM_API_KEY=                     # routing TIR + ruch (serwer /api/route i /api/traffic, incydenty); myto doszacowane (tollCost:0)
GRAPHHOPPER_API_KEY=                # fallback routingu (free tier: tylko car)

# ── Render mapy / geokoder (klient) ───────────────────────────
NEXT_PUBLIC_MAPTILER_KEY=           # style wektorowe, satelita, teren 3D, geokoder
NEXT_PUBLIC_TOMTOM_KEY=             # klient web: ten sam klucz co EXPO_PUBLIC_TOMTOM_KEY (mobile)
# TomTom (#356, klient-side): geokoder + routing TIR z ruchem na żywo + „POI po drodze".
# Mobile czyta EXPO_PUBLIC_TOMTOM_KEY (eas.json/.env). Pusty → fallback MapTiler/OSM + web /api/route.
EXPO_PUBLIC_TOMTOM_KEY=

# ── Domena (WebAuthn/passkey: zaufany origin) ─────────────────
NEXT_PUBLIC_SITE_URL=https://e-logistic-one.vercel.app
# Mobilny odpowiednik SITE_URL — baza URL panelu web dla apki (chat-notify,
# routing, ceny paliw, materiały tacho, linki zaproszeń). Pusty → produkcja.
EXPO_PUBLIC_WEB_BASE_URL=https://e-logistic-one.vercel.app

# ── Powiadomienia push (Web Push) — patrz DEPLOY.md §7 ────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=                  # sekret
VAPID_SUBJECT=mailto:admin@e-logistic.app
CRON_SECRET=                        # chroni /api/cron/notify (Vercel Cron)
EXPO_ACCESS_TOKEN=                  # opcjonalne — wyższe limity Expo Push API (mobile)

# ── Ceny paliwa (serwerowo, /api/fuel-prices) ─────────────────
FUEL_PRICE_API_KEY=                 # Tankerkönig (DE) — opcjonalne

# ── Fakturownia (serwerowo, /api/fakturownia/export) ──────────
FAKTUROWNIA_API_TOKEN=              # sekret: Ustawienia > Integracja > Kod API
FAKTUROWNIA_DOMAIN=                 # subdomena konta (np. „mojafirma" z mojafirma.fakturownia.pl)

# #306: Sentry (opcjonalnie) — monitoring błędów. DSN z sentry.io → Settings → Client Keys.
# Web: NEXT_PUBLIC_SENTRY_DSN (Vercel) · Mobile: EXPO_PUBLIC_SENTRY_DSN (eas.json env).
# NEXT_PUBLIC_SENTRY_DSN=
# EXPO_PUBLIC_SENTRY_DSN=

# #301: raporty tygodniowe PDF e-mailem (poniedziałkowy cron)
# Klucz z resend.com → API Keys. Bez zweryfikowanej domeny Resend wysyła tylko
# na adres właściciela konta (nadawca onboarding@resend.dev); po weryfikacji
# domeny ustaw EMAIL_FROM np. "E-Logistic <raporty@twojadomena.pl>".
RESEND_API_KEY=
# EMAIL_FROM="E-Logistic <onboarding@resend.dev>"

# ─────────────────────────────────────────────────────────────
#  PLANOWANE / jeszcze NIEUŻYWANE w kodzie (nie ustawiaj na razie):
#  PowerSync (offline), Twilio (SMS zaproszeń), Sentry (obserwowalność),
#  OAuth Google/Apple/Microsoft (konfiguracja w panelu Supabase, nie env).
# ─────────────────────────────────────────────────────────────

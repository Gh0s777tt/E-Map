# ─────────────────────────────────────────────────────────────
#  E-LOGISTIC — szablon zmiennych środowiskowych
#  Skopiuj do `.env` (web) / `.env.local` (Next) i uzupełnij.
#  NIGDY nie commituj prawdziwych wartości.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # tylko serwer/Edge Functions — NIGDY w kliencie
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── PowerSync (offline sync) ─────────────────────────────────
POWERSYNC_URL=
POWERSYNC_TOKEN=

# ── Mapy: routing TIR + myto (adapter RoutingProvider) ───────
ROUTING_PROVIDER=here               # here | graphhopper | valhalla
HERE_API_KEY=
GRAPHHOPPER_API_KEY=

# ── Render mapy / tile provider ──────────────────────────────
NEXT_PUBLIC_MAPTILER_KEY=
EXPO_PUBLIC_MAPTILER_KEY=

# ── Zaproszenia: SMS / WhatsApp ──────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── OAuth (konfigurowane też w panelu Supabase) ──────────────
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
AZURE_CLIENT_ID=

# ── Obserwowalność ───────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=
